APP_NAME="Londri API"
APP_VERSION="1.0.0"
ENVIRONMENT=development #development | staging | production
DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/laundry_db
# Sync URL used by Alembic for migrations (psycopg2 driver)
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/laundry_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_a_strong_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_HOUR=5

NOMBA_BASE_URL=https://sandbox.api.nomba.com/v1
NOMBA_CLIENT_ID=your_nomba_client_id
NOMBA_CLIENT_SECRET=your_nomba_client_secret
NOMBA_ACCOUNT_ID=your_nomba_primary_account_id
NOMBA_WEBHOOK_SECRET=your_nomba_webhook_hmac_secret

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM_NAME="Londri App"
SMTP_SENDER=no-reply@londri.app

REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
FRONTEND_URL="http://localhost:3000